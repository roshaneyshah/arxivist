# .env.example — copy to .env and fill in as needed.
# No secrets are required to run this repo's core pipeline (it is a
# closed-form statistical estimation + Monte Carlo simulation codebase with
# no external API calls). Variables below are optional overrides.

# Override the default config path used by scripts/*.py if desired.
ARXIVIST_CONFIG_PATH=configs/config.yaml

# Optional: force CPU-only execution even if model.engine: torch and a GPU is present.
CUDA_VISIBLE_DEVICES=

# Optional: directory to store large intermediate simulation outputs outside the repo.
ARXIVIST_RESULTS_DIR=results
