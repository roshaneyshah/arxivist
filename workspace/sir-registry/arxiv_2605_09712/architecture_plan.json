  "tensor_flow": [
    {
      "name": "Risk Metrics Forward Pass",
      "pseudocode": [
        "INPUT: losses_model [T], losses_benchmark [T]",
        "r = losses_benchmark - losses_model  → [T]  (return series)",
        "r_bar = mean(r)  → scalar",
        "s_r = std(r, ddof=1)  → scalar",
        "sharpe = r_bar / s_r  → scalar",
        "r_minus = clip(r, upper=0)  → [T]",
        "s_down = sqrt(mean(r_minus**2))  → scalar",
        "sortino = r_bar / s_down  → scalar",
        "r_plus = clip(r, lower=0)  → [T]",
        "omega = sum(r_plus) / sum(abs(r_minus))  → scalar",
        "R_cumsum = cumsum(r)  → [T]",
        "M_running = running_max(R_cumsum, prepend_zero=True)  → [T]",
        "DD = M_running - R_cumsum  → [T]",
        "max_dd = max(DD)  → scalar (negated for reporting)",
        "OUTPUT: {sharpe, sortino, omega, max_dd}"
      ]
    },
    {
      "name": "Edge Ratio Forward Pass",
      "pseudocode": [
        "INPUT: losses_all_models [M, T], model_idx int",
        "L_model = losses_all_models[model_idx, :]  → [T]",
        "L_competitors = losses_all_models[exclude model_idx, :]  → [M-1, T]",
        "L_star = min(L_competitors, axis=0)  → [T]  (frontier)",
        "e = L_star - L_model  → [T]",
        "e_plus = clip(e, lower=0)  → [T]",
        "e_minus = clip(-e, lower=0)  → [T]",
        "edge_ratio = (sum(e_plus) / sum(e_minus)) * (M - 1)  → scalar",
        "OUTPUT: edge_ratio"
      ]
    },
    {
      "name": "Expanding Window Evaluation Pass",
      "pseudocode": [
        "INPUT: panel_data [T_full, N_series], targets list, horizons list",
        "FOR each evaluation_period t in [T_start, T_end]:",
        "  X_train, y_train = panel_data[:t], targets[:t-h]",
        "  model.fit(X_train, y_train)",
        "  X_test = panel_data[t:t+1]",
        "  y_hat = model.predict(X_test)  → scalar",
        "  loss_t = loss_fn(y_true[t+h], y_hat)  → scalar",
        "END FOR",
        "OUTPUT: losses_dict[model_name] = [T_eval]"
      ]
    }
  ],
