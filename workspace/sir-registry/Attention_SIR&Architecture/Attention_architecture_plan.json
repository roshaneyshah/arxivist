  "risk_assessment": [
    {
      "severity": "Medium",
      "description": "Weight tying (3-way: encoder_embed = decoder_embed = pre_softmax_linear^T) is stated in the paper but exact tying scope is ambiguous (SIR confidence 0.82). Incorrect tying changes parameter count and may degrade results.",
      "source": "SIR ambiguity #2, Section 3.4",
      "mitigation": "Implement 3-way tying as primary; add config flag `weight_tying: true/false` to ablate."
    },
    {
      "severity": "Medium",
      "description": "Attention dropout scope unclear (SIR confidence 0.78). Paper only explicitly mentions residual and embedding dropout. Applying attention dropout affects training dynamics.",
      "source": "SIR ambiguity #1, Section 5.4",
      "mitigation": "Add separate `attention_dropout` config field defaulting to same value as `dropout`. Add TODO comment in code."
    },
    {
      "severity": "Medium",
      "description": "Token-based batching (25k tokens/batch) requires a custom TokenBatchSampler. Standard DataLoader with fixed batch_size will NOT reproduce the training regime.",
      "source": "SIR training_pipeline, Section 5.1",
      "mitigation": "Implement TokenBatchSampler with sort-by-length + bucket strategy. Unit test against expected token counts."
    },
    {
      "severity": "Low",
      "description": "LR schedule formula is fully specified (Eq. 3) but PyTorch's standard schedulers do not implement warmup_rsqrt_decay. Custom scheduler class required.",
      "source": "SIR mathematical_spec, Section 5.3",
      "mitigation": "Implement WarmupRsqrtScheduler as custom _LRScheduler subclass. Verified against formula values at step 1, 4000, 10000."
    },
    {
      "severity": "Low",
      "description": "Weight initialization strategy not specified in paper (SIR confidence 0.70). Xavier uniform is the standard default for Transformer implementations but affects training stability.",
      "source": "SIR implementation_assumptions[0]",
      "mitigation": "Apply Xavier uniform init in model __init__. Document clearly. Add config flag to swap if needed."
    },
