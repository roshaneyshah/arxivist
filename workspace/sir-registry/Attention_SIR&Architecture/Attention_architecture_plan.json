  "tensor_flows": [
    {
      "name": "EncoderForwardPass",
      "input": { "name": "src_token_ids", "shape": "[B, T_src]", "dtype": "int64" },
      "output": { "name": "encoder_memory", "shape": "[B, T_src, 512]", "dtype": "float32" },
      "steps": [
        "src_embed = token_embedding(src_token_ids) * sqrt(d_model)  → [B, T_src, 512]",
        "src_embed = positional_encoding(src_embed)                  → [B, T_src, 512]  (dropout applied)",
        "src_mask = make_padding_mask(src_token_ids, pad_idx)        → [B, 1, 1, T_src]",
        "for each EncoderLayer (N=6):",
        "  residual = x",
        "  x = self_attention(x, x, x, mask=src_mask)               → [B, T_src, 512]",
        "  x = dropout(x) + residual",
        "  x = layer_norm(x)                                         → [B, T_src, 512]",
        "  residual = x",
        "  x = feedforward(x)                                        → [B, T_src, 512]",
        "  x = dropout(x) + residual",
        "  x = layer_norm(x)                                         → [B, T_src, 512]",
        "return x as encoder_memory                                   → [B, T_src, 512]"
      ]
    },
    {
      "name": "DecoderForwardPass",
      "input": { "name": "tgt_token_ids", "shape": "[B, T_tgt]", "dtype": "int64" },
      "output": { "name": "logits", "shape": "[B, T_tgt, vocab_size]", "dtype": "float32" },
      "steps": [
        "tgt_embed = token_embedding(tgt_token_ids) * sqrt(d_model)  → [B, T_tgt, 512]",
        "tgt_embed = positional_encoding(tgt_embed)                  → [B, T_tgt, 512]  (dropout applied)",
        "tgt_mask = causal_mask(T_tgt) & padding_mask(tgt_ids)       → [B, 1, T_tgt, T_tgt]",
        "for each DecoderLayer (N=6):",
        "  residual = x",
        "  x = masked_self_attention(x, x, x, mask=tgt_mask)        → [B, T_tgt, 512]",
        "  x = dropout(x) + residual; x = layer_norm(x)",
        "  residual = x",
        "  x = cross_attention(q=x, k=memory, v=memory, mask=src_mask) → [B, T_tgt, 512]",
        "  x = dropout(x) + residual; x = layer_norm(x)",
        "  residual = x",
        "  x = feedforward(x)                                        → [B, T_tgt, 512]",
        "  x = dropout(x) + residual; x = layer_norm(x)",
        "logits = linear(x)  [weight-tied to embedding]              → [B, T_tgt, vocab_size]",
        "return logits (no softmax applied — loss handles it)"
      ]
    },
    {
      "name": "ScaledDotProductAttentionPass",
      "input": { "name": "Q,K,V projections", "shape": "[B, h, T, d_k]", "dtype": "float32" },
      "output": { "name": "attention_output", "shape": "[B, h, T, d_v]", "dtype": "float32" },
      "steps": [
        "scores = matmul(Q, K.transpose(-2,-1)) / sqrt(d_k)          → [B, h, T_q, T_k]",
        "if mask is not None: scores = scores.masked_fill(mask==0, -1e9)",
        "attn_weights = softmax(scores, dim=-1)                       → [B, h, T_q, T_k]",
        "attn_weights = dropout(attn_weights)  # attention dropout",
        "output = matmul(attn_weights, V)                             → [B, h, T_q, d_v]",
        "return output, attn_weights"
      ]
    },
    {
      "name": "MultiHeadAttentionPass",
      "input": { "name": "Q,K,V", "shape": "[B, T, d_model]", "dtype": "float32" },
      "output": { "name": "mha_output", "shape": "[B, T, d_model]", "dtype": "float32" },
      "steps": [
        "Q_proj = linear_Q(Q).view(B, T_q, h, d_k).transpose(1,2)   → [B, h, T_q, d_k]",
        "K_proj = linear_K(K).view(B, T_k, h, d_k).transpose(1,2)   → [B, h, T_k, d_k]",
        "V_proj = linear_V(V).view(B, T_v, h, d_v).transpose(1,2)   → [B, h, T_v, d_v]",
        "context, attn = scaled_dot_product_attention(Q_proj, K_proj, V_proj, mask)",
        "context = context.transpose(1,2).contiguous().view(B, T_q, h*d_v)  → [B, T_q, 512]",
        "output = linear_O(context)                                   → [B, T_q, d_model]",
        "return output, attn"
      ]
    }
  ],

