  "tensor_flow": {
    "training_pass": "BACKWARD INDUCTION LOOP:\n  for t = T downto 0:\n    for each order_book_snapshot in training_data:\n      compute market_vars o1..oR from snapshot (discretized)\n      for i in 0..I:\n        for a in 0..L:\n          state_idx = encode(t, i, o1..oR)  → scalar int\n          shares_executed, cost_im = simulate_execution(snapshot, i*V/I, ask-a)\n          next_i = i - shares_executed_units\n          next_state_idx = encode(t+1, next_i, next_market_vars)\n          best_future = q_table.best_action(next_state_idx)\n          n = visit_count[state_idx, a]\n          q_table[state_idx, a] = n/(n+1)*q_table[state_idx,a] + 1/(n+1)*(cost_im + best_future)\n          visit_count[state_idx, a] += 1",
    "inference_pass": "INFERENCE:\n  given current state (t, i, order_book_snapshot):\n    market_vars = extract_features(snapshot)\n    state_idx = encode(t, i, market_vars)\n    action = argmin_a q_table[state_idx, a]\n    limit_price = ask - action\n    submit limit order at limit_price for i*V/I shares"
  },
  "config_schema": {
    "template_path": "configs/experiment.yaml",
    "fields": {
      "experiment": {
        "stock": "AMZN  # one of: AMZN, NVDA, QCOM",
        "V": "10000  # total shares to execute",
        "H_minutes": "2  # execution horizon",
        "side": "sell  # buy or sell"
      },
      "state_space": {
        "T": "8  # time resolution (decision points)",
        "I": "8  # inventory resolution levels",
        "market_variables": "['bid_ask_spread', 'immediate_market_order_cost']",
        "n_bins_market": "3  # discretization bins per market variable # ASSUMED: paper states 3 for tx volume, implied for others"
      },
      "action_space": {
        "L": "21  # number of discrete price offset actions # ASSUMED: inferred from figures, confidence=0.60",
        "action_min": "-6  # most passive (deep in own book)",
        "action_max": "14  # most aggressive (cross spread)"
      },
      "training": {
        "data_path": "data/raw/",
        "train_months": 12,
        "test_months": 6
      },
      "evaluation": {
        "output_dir": "results/",
        "report_stocks": "['AMZN', 'NVDA', 'QCOM']"
      }
    }
  },
